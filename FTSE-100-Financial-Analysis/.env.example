# Optional: enable live pulls (first run) + caching (subsequent runs)
# Default behaviour is OFFLINE-FIRST using the shipped snapshots.

# Provider name: yahoo | stooq | alphavantage | polygon
FTSE100_PROVIDER=yahoo

# Symbol per provider
# - Yahoo: ^FTSE (FTSE 100 index)
# - Stooq: ^ukx (FTSE 100 / UKX)
FTSE100_SYMBOL=^FTSE

# Cache directory (if empty, defaults to data_cache/)
FTSE100_CACHE_DIR=./data_cache

# API keys (only needed for the relevant provider)
ALPHAVANTAGE_API_KEY=
POLYGON_API_KEY=
